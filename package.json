{
  "name": "oembed-spec",
  "description": "A parser for oEmbed specification",
  "homepage": "https://github.com/microlinkhq/oembed-spec",
  "version": "1.3.33",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "author": {
    "email": "hello@microlink.io",
    "name": "microlink.io",
    "url": "https://microlink.io"
  },
  "contributors": [
    {
      "name": "Kiko Beats",
      "email": "josefrancisco.verdu@gmail.com"
    },
    {
      "name": "Rémi",
      "email": "remusao@users.noreply.github.com"
    },
    {
      "name": "Rémi Berson",
      "email": "remi@cliqz.com"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/microlinkhq/oembed-spec.git"
  },
  "bugs": {
    "url": "https://github.com/microlinkhq/oembed-spec/issues"
  },
  "keywords": [
    "oembed",
    "parser",
    "spec"
  ],
  "dependencies": {
    "got": "~11.8.6",
    "tldts": "~7.0.7"
  },
  "devDependencies": {
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "@ksmithut/prettier-standard": "latest",
    "@microlink/demo-links": "latest",
    "ava": "latest",
    "benchmark": "latest",
    "big-list-of-naughty-strings": "latest",
    "c8": "latest",
    "chalk": "latest",
    "ci-publish": "latest",
    "finepack": "latest",
    "git-authors-cli": "latest",
    "github-generate-release": "latest",
    "nano-staged": "latest",
    "oembed-parser": "latest",
    "simple-git-hooks": "latest",
    "standard": "latest",
    "standard-version": "latest"
  },
  "engines": {
    "node": ">= 10"
  },
  "files": [
    "scripts",
    "src"
  ],
  "scripts": {
    "benchmark": "node ./benchmarks/benchmark.js",
    "clean": "rm -rf node_modules",
    "contributors": "(npx git-authors-cli && npx finepack && git add package.json && git commit -m 'build: contributors' --no-verify) || true",
    "lint": "standard",
    "postrelease": "pnpm release:tags && pnpm release:github && (ci-publish || npm publish --access=public)",
    "pretest": "pnpm lint",
    "release": "standard-version -a",
    "release:github": "github-generate-release",
    "release:tags": "git push --follow-tags origin HEAD:master",
    "test": "c8 ava"
  },
  "license": "MIT",
  "ava": {
    "files": [
      "test/**/*",
      "!test/helpers/**/*"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "body-max-line-length": [
        0
      ]
    }
  },
  "nano-staged": {
    "*.js": [
      "prettier-standard",
      "standard --fix"
    ],
    "package.json": [
      "finepack"
    ]
  },
  "simple-git-hooks": {
    "commit-msg": "npx commitlint --edit",
    "pre-commit": "npx nano-staged"
  }
}
